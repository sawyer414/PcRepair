 # .htaccess - Basic Security Configuration
 # HTTPS redirect is handled at the server level in 000-default.conf

 # Security Header
<IfModule mod_headers.c>
    # Force HTTPS in browsers
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    # Prevent clickjacking attacks
    Header set X-Frame-Options "SAMEORIGIN"
    # Enable XSS protection
    Header set X-XSS-Protection "1; mode=block"
    # Prevent MIME type sniffing
    Header set X-Content-Type-Options "nosniff"
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    # Permissions Policy
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # Content Security Policy — allows Google Forms and Google Fonts
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://docs.google.com https://forms.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://docs.google.com https://forms.google.com; frame-src https://docs.google.com https://forms.google.com;"
</IfModule>

 # File Access Protection
 # Protect sensitive files
<FilesMatch "\.(bat|txt|md|json|scss)$">
    Require all denied
</FilesMatch>

 # Protect package.json and notes
<Files "package.json">
    Require all denied
</Files>

 # Protect .htaccess itself
<Files ".htaccess">
    Require all denied
</Files>

 # Block access to hidden files
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

 # Directory Listing Protection
Options -Indexes

 # Server Signature
ServerSignature Off

 # Disable ETags
FileETag None

 # URL rewriting, injection protection, and clean URLs
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block script injection via query strings
    RewriteCond %{QUERY_STRING} (<|%3C).*script.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|[|%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|[|%[0-9A-Z]{0,2})
    RewriteRule ^(.*)$ index.html [F,L]

    # Serve PHP files without the extension (checked first)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L]

    # Serve HTML files without the extension
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.*)$ $1.html [L]

    # Remove .html extension from URLs
    RewriteCond %{THE_REQUEST} \.html[\s?] [NC]
    RewriteRule ^(.*)\.html$ /$1 [R=301,L]

    # Remove .php extension from URLs
    RewriteCond %{THE_REQUEST} \.php[\s?] [NC]
#    RewriteRule ^(.*)\.php$ /$1 [R=301,L]

    # Redirect /index or /index.html to /
#    RewriteRule ^index(\.html)?$ / [R=301,L]
</IfModule>
