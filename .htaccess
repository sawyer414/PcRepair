# .htaccess - Basic Security Configuration
# HTTPS redirect is handled at the server level in 000-default.conf

# Security Headers
<IfModule mod_rewrite.c>
    RewriteEngine On

    # === Security: Block common attacks ===
    RewriteCond %{QUERY_STRING} (<|%3C).*script.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|[|%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|[|%[0-9A-Z]{0,2})
    RewriteRule ^(.*)$ index.html [F,L]

    # === Extensionless URLs (Clean + Safe) ===
    
    # 1. Internally rewrite clean URL to .php (if the .php file exists)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L]

    # 2. Internally rewrite clean URL to .html (if the .html file exists)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.*)$ $1.html [L]

    # 3. Remove .php from browser URL (only if directly requested)
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\s/(.+)\.php[\s?] [NC]
    RewriteRule ^(.+)\.php$ /$1 [R=301,L,QSA]

    # 4. Remove .html from browser URL
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\s/(.+)\.html[\s?] [NC]
    RewriteRule ^(.+)\.html$ /$1 [R=301,L,QSA]

    # Redirect /index and /index.* to root
    RewriteRule ^index(\.html|\.php)?$ / [R=301,L]
</IfModule>

# File Access Protection
# Protect sensitive files
<FilesMatch "\.(bat|txt|md|json|scss)$">
    Require all denied
</FilesMatch>

# Protect package.json and notes
<Files "package.json">
    Require all denied
</Files>

# Protect .htaccess itself
<Files ".htaccess">
    Require all denied
</Files>

# Block access to hidden files
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Directory Listing Protection
Options -Indexes

# Server Signature
ServerSignature Off

# Disable ETags
FileETag None

# URL rewriting, injection protection, and clean URLs
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block script injection via query strings
    RewriteCond %{QUERY_STRING} (<|%3C).*script.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|[|%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|[|%[0-9A-Z]{0,2})
    RewriteRule ^(.*)$ index.html [F,L]

    # Serve PHP files without the extension (checked first)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L]

    # Serve HTML files without the extension
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.*)$ $1.html [L]

    # Remove .html extension from URLs
    RewriteCond %{THE_REQUEST} \.html[\s?] [NC]
    RewriteRule ^(.*)\.html$ /$1 [R=301,L]

    # Remove .php extension from URLs
    RewriteCond %{THE_REQUEST} \.php[\s?] [NC]
    RewriteRule ^(.*)\.php$ /$1 [R=301,L]

    # Redirect /index or /index.html to /
    RewriteRule ^index(\.html)?$ / [R=301,L]
</IfModule>
